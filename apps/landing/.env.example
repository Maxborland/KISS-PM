# KISS PM Landing — environment variables

# Resend (optional). If empty, waitlist notification falls back to console + SQLite only.
RESEND_API_KEY=
RESEND_FROM="KISS PM <noreply@kisspm.app>"
RESEND_NOTIFY_TO=

# Telegram notifications (optional, works alongside Resend).
# Bot: create via @BotFather -> token. Chat id: write to the bot, then open
# https://api.telegram.org/bot<TOKEN>/getUpdates -> message.chat.id
# (for a group: add the bot to the group and use the negative chat id).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SQLite location (absolute or relative to apps/landing).
WAITLIST_DB_PATH=./data/waitlist.sqlite

# Origin allowlist for form submissions (comma separated). Leave empty in dev.
WAITLIST_ALLOWED_ORIGINS=

# Salt for one-way IP hashing (anti-spam). REQUIRED in production:
# without it the server refuses to hash, dev uses a throwaway dev-only salt.
# Generate: openssl rand -hex 24
WAITLIST_IP_SALT=
