---
---

<section id="philosophy" class="l-band l-band--panel" aria-labelledby="philosophy-title">
  <div class="l-container">
    <header class="section-head section-head--tight">
      <h2 id="philosophy-title" class="l-display" data-text-reveal>
        Простота снаружи.<br />Контур внутри.
      </h2>
    </header>

    <div class="philosophy-grid" data-bento-group>
      <article class="philosophy-hero kp-spotlight-card">
        <p class="philosophy-hero__display" data-text-reveal>
          KISS = <em>Keep</em> · <em>It</em> · <em>Simple</em> · <em>Seriously!</em>
        </p>
      </article>

      <article class="bento__cell bento__cell--feature">
        <span class="bento__kicker">Сигнал</span>
        <h3 class="bento__title" data-text-reveal>До срыва</h3>
        <svg class="kp-spark kp-spark--magenta" viewBox="0 0 240 44" preserveAspectRatio="none" aria-hidden="true">
          <path
            d="M0 32 L48 28 L96 22 L144 20 L192 12 L240 8"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
          />
        </svg>
      </article>

      <article class="bento__cell">
        <span class="bento__kicker">Настройки</span>
        <h3 class="bento__title" data-text-reveal>Не в коде</h3>
      </article>
    </div>
  </div>
</section>
