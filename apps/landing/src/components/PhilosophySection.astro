---
import PhilosophyShader from "./PhilosophyShader.tsx";
import { copyFor, type LandingLocale } from "../lib/landing-i18n";

interface Props {
  locale?: LandingLocale;
}

const { locale = "ru" } = Astro.props;
const copy = copyFor(locale).philosophy;
---

<section id="philosophy" class="philosophy" aria-labelledby="philosophy-title">
  <PhilosophyShader client:visible />

  <div class="l-container philosophy__inner">
    <h2 id="philosophy-title" class="philosophy__display" data-text-reveal>
      {copy.title}
    </h2>

    <div class="philosophy__lines">
      {copy.lines.map((line) => (
        <p class="philosophy__line" data-text-reveal>{line}</p>
      ))}
    </div>
  </div>
</section>