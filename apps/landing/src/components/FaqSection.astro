---
import { copyFor, type LandingLocale } from "../lib/landing-i18n";
import { faqsByLocale } from "../lib/landing-faq";

interface Props {
  locale?: LandingLocale;
}

const { locale = "ru" } = Astro.props;
const copy = copyFor(locale);
const faqs = faqsByLocale[locale];
---

<section id="faq" class="l-band l-band--panel" aria-labelledby="faq-title">
  <div class="l-container">
    <div class="faq">
      <header class="section-head section-head--tight">
        <h2
          id="faq-title"
          class="l-display"
          style="font-size:clamp(1.8rem, 3.4vw, 2.4rem)"
          data-text-reveal
        >
          {copy.faqTitle}
        </h2>
      </header>

      <div class="faq__list" data-reveal>
        {faqs.map((item) => (
          <details class="faq__item">
            <summary class="faq__summary">
              <span>{item.q}</span>
              <span class="faq__chev" aria-hidden="true">
                <svg viewBox="0 0 16 16" width="14" height="14">
                  <path
                    d="M4 6l4 4 4-4"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </span>
            </summary>
            <p class="faq__answer">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>