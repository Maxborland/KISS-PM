---
const steps = [
  { no: "01", kicker: "Спрос", title: "Возможность в системе", gantt: false },
  { no: "02", kicker: "Приёмка", title: "Черновик проекта", gantt: false },
  { no: "03", kicker: "Ёмкость", title: "Проверка загрузки", gantt: false },
  { no: "04", kicker: "План", title: "Живой график", gantt: true },
  { no: "05", kicker: "Сигнал", title: "Управленческое действие", gantt: false },
  { no: "06", kicker: "Закрытие", title: "Уроки в шаблон", gantt: false },
];
---

<section id="loop" class="l-band l-band--canvas" aria-labelledby="loop-title">
  <div class="l-container">
    <header class="section-head section-head--tight">
      <h2 id="loop-title" class="l-display" data-text-reveal>
        Шесть шагов · один язык
      </h2>
    </header>

    <div class="hscroll-wrap" data-hscroll data-hscroll-wheel="true" data-bento-group>
      <div class="loop-rail hscroll" data-hscroll-rail role="list">
        {steps.map((step) => (
          <article
            class={`loop-rail__card hscroll__item${step.gantt ? " loop-rail__card--wide" : ""}`}
            data-hscroll-item
            role="listitem"
          >
            <div class="loop-stepper">
              <span class="loop-stepper__no">{step.no}</span>
              <span class="loop-stepper__line" aria-hidden="true"></span>
            </div>
            <span class="bento__kicker">{step.kicker}</span>
            <h3 class="bento__title" data-text-reveal>{step.title}</h3>
            {step.gantt && (
              <div class="kp-gantt" aria-hidden="true">
                <div class="kp-gantt__row">
                  <span>Разработка</span>
                  <div class="kp-gantt__track">
                    <span class="kp-gantt__bar" style="left:20%;width:55%"></span>
                    <span class="kp-gantt__playhead" style="left:48%"></span>
                  </div>
                </div>
              </div>
            )}
          </article>
        ))}
      </div>
      <div class="hscroll-foot hscroll-foot--dots-only">
        <nav class="hscroll-dots" aria-label="Шаги контура">
          {steps.map((_, idx) => (
            <button
              type="button"
              class="hscroll-dots__dot"
              data-hscroll-dot
              aria-current={idx === 0 ? "true" : undefined}
              aria-label={`Шаг ${idx + 1}`}
            ></button>
          ))}
        </nav>
      </div>
    </div>
  </div>
</section>
