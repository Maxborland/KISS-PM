---
const items: Array<{ href: string; label: string; id: string }> = [
  { href: "/#portfolio", label: "Масштаб", id: "portfolio" },
  { href: "/#philosophy", label: "Философия", id: "philosophy" },
  { href: "/#loop", label: "Контур", id: "loop" },
  { href: "/#demo", label: "Сценарий", id: "demo" },
  { href: "/#scope", label: "Управление", id: "scope" },
  { href: "/#waitlist", label: "Альфа", id: "waitlist" },
  { href: "/#faq", label: "Вопросы", id: "faq" },
];
---

<header class="site-header" data-site-header>
  <div class="l-container site-header__inner">
    <a class="site-header__brand" href="/">
      <span class="site-header__mark" aria-hidden="true">
        <svg viewBox="0 0 32 32" width="22" height="22">
          <defs>
            <linearGradient id="kiss-mark" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#6665ff" />
              <stop offset="55%" stop-color="#f45bff" />
              <stop offset="100%" stop-color="#8ef6ff" />
            </linearGradient>
          </defs>
          <rect x="2" y="2" width="28" height="28" rx="8" fill="url(#kiss-mark)" />
          <path
            d="M10 22V10h2.6v5.2L18 10h3.3l-5.2 5.6L21.6 22h-3.4l-3.7-5-1.9 2v3H10z"
            fill="#fff"
          />
        </svg>
      </span>
      <span class="site-header__name">KISS PM</span>
    </a>

    <nav class="site-header__nav" aria-label="Навигация по разделам">
      {items.map((item) => (
        <a href={item.href} class="site-header__link" data-section-link={item.id}>
          <span>{item.label}</span>
        </a>
      ))}
    </nav>

    <div class="site-header__cta">
      <a class="l-btn l-btn--ghost site-header__cta-btn" href="/#waitlist">
        <span>Запросить доступ</span>
        <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
          <path d="M3 8h9m0 0L8.5 4.5M12 8l-3.5 3.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    padding-block: 14px;
    background: transparent;
    backdrop-filter: none;
    border-bottom: 1px solid transparent;
    transition:
      opacity var(--duration-ui) var(--ease-out),
      transform var(--duration-ui) var(--ease-out),
      visibility var(--duration-ui) var(--ease-out),
      max-height var(--duration-ui) var(--ease-out),
      padding-block var(--duration-ui) var(--ease-out),
      background var(--duration-ui) var(--ease-out),
      border-color var(--duration-ui) var(--ease-out),
      backdrop-filter var(--duration-ui) var(--ease-out),
      box-shadow var(--duration-ui) var(--ease-out);
  }

  /* Весь header скрыт на hero — появляется со второго блока */
  .site-header:not([data-past-hero="true"]) {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    max-height: 0;
    padding-block: 0;
    overflow: hidden;
    transform: translateY(-12px);
    border-bottom-color: transparent;
    box-shadow: none;
  }

  .site-header[data-past-hero="true"] {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    max-height: 120px;
    padding-block: 14px;
    transform: translateY(0);
    background: rgba(248, 250, 252, 0.82);
    backdrop-filter: blur(18px) saturate(150%);
    border-bottom-color: rgba(15, 23, 42, 0.06);
    box-shadow: 0 10px 30px -24px rgba(15, 23, 42, 0.4);
  }

  .site-header[data-past-hero="true"][data-scrolled="true"] {
    background: rgba(248, 250, 252, 0.88);
  }

  .site-header::after {
    content: "";
    position: absolute;
    inset: auto 0 -1px 0;
    height: 1px;
    background: var(--gradient-plasma-line);
    opacity: 0;
    transition: opacity var(--duration-ui) var(--ease-out);
    pointer-events: none;
  }

  .site-header[data-past-hero="true"]::after {
    opacity: 0.5;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    gap: clamp(12px, 2vw, 20px);
    min-width: 0;
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--text-strong);
    font-weight: 700;
    border: 0;
  }

  .site-header__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 10px;
    box-shadow:
      0 4px 14px -2px rgba(102, 101, 255, 0.45),
      0 1px 0 rgba(255, 255, 255, 0.6) inset;
    transition:
      transform var(--duration-ui) var(--ease-ui),
      box-shadow var(--duration-ui) var(--ease-ui);
  }

  .site-header__brand:hover .site-header__mark {
    transform: translateY(-1px) rotate(-4deg) scale(1.04);
    box-shadow:
      0 8px 24px -4px rgba(244, 91, 255, 0.45),
      0 1px 0 rgba(255, 255, 255, 0.7) inset;
  }

  .site-header__name {
    font-family: var(--font-display);
    font-size: 17px;
    letter-spacing: -0.01em;
  }

  .site-header__badge {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted-strong);
    padding: 3px 8px;
    border-radius: var(--radius-full);
    background: var(--panel);
    border: 1px solid var(--border);
    transition:
      color var(--duration-ui) var(--ease-ui),
      border-color var(--duration-ui) var(--ease-ui);
  }

  .site-header__brand:hover .site-header__badge {
    color: var(--text-strong);
    border-color: color-mix(in oklab, var(--border-strong) 50%, var(--plasma-violet) 50%);
  }

  .site-header__nav {
    display: none;
    margin-inline: auto;
    gap: 2px;
    position: relative;
    flex-wrap: wrap;
    justify-content: center;
    min-width: 0;
  }

  .site-header__link {
    position: relative;
    color: var(--muted-strong);
    font-weight: 500;
    font-size: 13px;
    padding: 8px 10px;
    border-radius: var(--radius-md);
    border: 0;
    transition: color var(--duration-ui) var(--ease-ui);
  }

  .site-header__link > span {
    position: relative;
    z-index: 1;
  }

  .site-header__link::before {
    content: "";
    position: absolute;
    inset: 4px 6px;
    border-radius: 8px;
    background: var(--panel);
    opacity: 0;
    transform: scale(0.92);
    transition:
      opacity var(--duration-ui) var(--ease-ui),
      transform var(--duration-ui) var(--ease-ui);
  }

  .site-header__link:hover {
    color: var(--text-strong);
  }

  .site-header__link:hover::before {
    opacity: 1;
    transform: scale(1);
  }

  .site-header__link[data-active="true"] {
    color: var(--text-strong);
  }

  .site-header__link[data-active="true"]::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 2px;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    transform: translateX(-50%);
    background: linear-gradient(90deg, var(--plasma-violet), var(--plasma-magenta));
    box-shadow: 0 0 12px rgba(244, 91, 255, 0.5);
  }

  .site-header__cta {
    margin-left: auto;
    display: inline-flex;
    gap: 12px;
  }

  .site-header__cta-btn {
    height: 40px;
    padding-inline: 16px;
    font-size: 13.5px;
    gap: 6px;
  }

  .site-header__cta-btn svg {
    transition: transform var(--duration-ui) var(--ease-ui);
  }

  .site-header__cta-btn:hover svg {
    transform: translateX(3px);
  }

  @media (min-width: 880px) {
    .site-header__nav {
      display: inline-flex;
    }
    .site-header__cta {
      margin-left: 0;
      flex-shrink: 0;
    }
    .site-header__brand {
      flex-shrink: 0;
    }
  }

  @media (min-width: 880px) and (max-width: 1180px) {
    .site-header__inner {
      flex-wrap: wrap;
      row-gap: 10px;
    }
    .site-header__nav {
      order: 3;
      width: 100%;
    }
  }
</style>

<script>
  // Past-hero nav reveal + scroll chrome + active section underline.
  const header = document.querySelector<HTMLElement>("[data-site-header]");
  if (header) {
    const hero = document.getElementById("hero");

    const onScroll = () => {
      header.dataset.scrolled = window.scrollY > 8 ? "true" : "false";
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });

    // Hidden only while hero is on screen. Once you scroll past hero, nav stays
    // visible for all following blocks (it must not re-hide when philosophy scrolls away).
    if (hero) {
      const heroObserver = new IntersectionObserver(
        ([entry]) => {
          const onHero =
            entry.isIntersecting && entry.intersectionRatio > 0.12;
          header.dataset.pastHero = onHero ? "false" : "true";
        },
        { threshold: [0, 0.12, 0.35, 0.6, 1] }
      );
      heroObserver.observe(hero);
    } else {
      header.dataset.pastHero = "true";
    }

    const links = Array.from(
      document.querySelectorAll<HTMLAnchorElement>("[data-section-link]")
    );
    const sectionMap = new Map<string, HTMLAnchorElement>();
    links.forEach((link) => {
      const id = link.dataset.sectionLink;
      if (id) sectionMap.set(id, link);
    });

    const setActive = (id: string) => {
      links.forEach((link) => {
        link.dataset.active = link.dataset.sectionLink === id ? "true" : "false";
      });
    };

    const sections = Array.from(sectionMap.keys())
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => Boolean(el));

    if (sections.length) {
      const io = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
          if (visible[0]) setActive(visible[0].target.id);
        },
        { rootMargin: "-40% 0px -55% 0px", threshold: [0, 0.25, 0.5, 0.75, 1] }
      );
      sections.forEach((s) => io.observe(s));
    }
  }
</script>
