---
import { copyFor, type LandingLocale } from "../lib/landing-i18n";

interface Props {
  locale?: LandingLocale;
  sectionHrefPrefix?: string;
  ctaHref?: string;
  localeHref?: string;
}

const { locale = "ru", sectionHrefPrefix = "", ctaHref, localeHref } = Astro.props;
const copy = copyFor(locale).header;
const items = copy.items;
const sectionHref = (href: string) =>
  sectionHrefPrefix && href.startsWith("#") ? `${sectionHrefPrefix}${href}` : href;
const resolvedCtaHref = ctaHref ?? sectionHref("#waitlist");
const resolvedLocaleHref = localeHref ?? copy.localeHref;
---

<header class="site-header" data-site-header>
  <div class="l-container site-header__inner">
    <a class="site-header__brand" href={copy.brandHref}>
      <span class="site-header__mark" aria-hidden="true">
        <svg viewBox="0 0 32 32" width="22" height="22">
          <rect x="2" y="2" width="28" height="28" rx="8" fill="currentColor" />
          <path
            d="M10 22V10h2.6v5.2L18 10h3.3l-5.2 5.6L21.6 22h-3.4l-3.7-5-1.9 2v3H10z"
            fill="#fff"
          />
        </svg>
      </span>
      <span class="site-header__name">KISS PM</span>
    </a>

    <nav class="site-header__nav" aria-label={copy.navLabel}>
      {items.map((item) => (
        <a href={sectionHref(item.href)} class="site-header__link" data-section-link={item.id}>
          <span>{item.label}</span>
        </a>
      ))}
    </nav>

    <div class="site-header__cta">
      <a class="site-header__locale" href={resolvedLocaleHref} hreflang={locale === "ru" ? "en" : "ru"}>
        {copy.localeLabel}
      </a>
      <a class="l-btn l-btn--ghost site-header__cta-btn" href={resolvedCtaHref}>
        <span>{copy.cta}</span>
        <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
          <path d="M3 8h9m0 0L8.5 4.5M12 8l-3.5 3.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    padding-block: 16px;
    background: transparent;
    backdrop-filter: none;
    border-bottom: 1px solid transparent;
    transition:
      opacity var(--duration-ui) var(--ease-out),
      transform var(--duration-ui) var(--ease-out),
      visibility var(--duration-ui) var(--ease-out),
      max-height var(--duration-ui) var(--ease-out),
      padding-block var(--duration-ui) var(--ease-out),
      background var(--duration-ui) var(--ease-out),
      border-color var(--duration-ui) var(--ease-out),
      backdrop-filter var(--duration-ui) var(--ease-out),
      box-shadow var(--duration-ui) var(--ease-out);
  }

  .site-header:not([data-past-hero="true"]) {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    max-height: 0;
    padding-block: 0;
    overflow: hidden;
    transform: translateY(-12px);
    border-bottom-color: transparent;
    box-shadow: none;
  }

  .site-header[data-past-hero="true"] {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    max-height: 132px;
    padding-block: 16px;
    transform: translateY(0);
    background: transparent;
    backdrop-filter: none;
    border-bottom-color: transparent;
    box-shadow: none;
  }

  .site-header[data-past-hero="true"][data-scrolled="true"] {
    background: transparent;
  }

  .site-header[data-demo-dimmed="true"] {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(-14px);
  }

  .site-header::after {
    content: "";
    position: absolute;
    inset: auto 0 -1px 0;
    height: 1px;
    background: var(--gradient-plasma-line);
    opacity: 0;
    transition: opacity var(--duration-ui) var(--ease-out);
    pointer-events: none;
  }

  .site-header[data-past-hero="true"]::after {
    opacity: 0;
  }

  .site-header__inner {
    position: relative;
    display: flex;
    align-items: center;
    gap: clamp(12px, 2vw, 20px);
    min-width: 0;
    min-height: 76px;
    overflow: hidden;
    border: 1px solid transparent;
    border-radius: 24px;
    transition:
      background var(--duration-ui) var(--ease-out),
      border-color var(--duration-ui) var(--ease-out),
      box-shadow var(--duration-ui) var(--ease-out),
      backdrop-filter var(--duration-ui) var(--ease-out);
  }

  .site-header[data-past-hero="true"] .site-header__inner {
    border-color: rgba(15, 23, 42, 0.1);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.42));
    box-shadow:
      0 34px 84px -54px rgba(15, 23, 42, 0.58),
      0 1px 0 rgba(255, 255, 255, 0.98) inset,
      0 -1px 0 rgba(15, 23, 42, 0.06) inset;
    backdrop-filter: blur(34px) saturate(190%);
  }

  .site-header[data-past-hero="true"][data-scrolled="true"] .site-header__inner {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.48));
  }

  .site-header__inner::before,
  .site-header__inner::after {
    content: "";
    position: absolute;
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--duration-ui) var(--ease-out);
  }

  .site-header__inner::before {
    inset: 0;
    border-radius: inherit;
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.72), transparent 34%, rgba(255, 255, 255, 0.48) 70%, transparent),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.56), transparent 42%);
  }

  .site-header__inner::after {
    inset: 1px;
    border-radius: 21px;
    border: 1px solid rgba(255, 255, 255, 0.48);
    box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.025) inset;
  }

  .site-header[data-past-hero="true"] .site-header__inner::before,
  .site-header[data-past-hero="true"] .site-header__inner::after {
    opacity: 1;
  }

  .site-header__brand {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--text-strong);
    font-weight: 700;
    border: 0;
  }

  .site-header__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 10px;
    color: var(--text-strong);
    transition: transform var(--duration-ui) var(--ease-ui);
  }

  .site-header__brand:hover .site-header__mark {
    transform: translateY(-1px) scale(1.04);
  }

  .site-header__name {
    font-family: var(--font-display);
    font-size: 17px;
    letter-spacing: -0.01em;
  }

  .site-header__nav {
    z-index: 1;
    display: none;
    margin-inline: auto;
    gap: 2px;
    position: relative;
    flex-wrap: wrap;
    justify-content: center;
    min-width: 0;
  }

  .site-header__link {
    position: relative;
    color: var(--muted-strong);
    font-weight: 500;
    font-size: 13px;
    padding: 8px 10px;
    border-radius: var(--radius-md);
    border: 0;
    transform: translate3d(0, 0, 0);
    transition:
      color var(--duration-ui) var(--ease-ui),
      transform var(--duration-ui) var(--ease-soft);
  }

  .site-header__link > span {
    position: relative;
    z-index: 1;
  }

  .site-header__link::before {
    content: "";
    position: absolute;
    inset: 4px 6px;
    border-radius: 8px;
    background:
      radial-gradient(70% 100% at 50% 0%, rgba(255, 255, 255, 0.92), rgba(15, 23, 42, 0.05)),
      rgba(255, 255, 255, 0.58);
    box-shadow:
      0 0 0 1px rgba(15, 23, 42, 0.045),
      0 1px 0 rgba(255, 255, 255, 0.88) inset;
    opacity: 0;
    transform: scale(0.92);
    transition:
      opacity var(--duration-ui) var(--ease-ui),
      transform var(--duration-ui) var(--ease-ui);
  }

  .site-header__link:hover {
    color: var(--text-strong);
    transform: translate3d(0, -1px, 0);
  }

  .site-header__link:hover::before {
    opacity: 1;
    transform: scale(1);
  }

  .site-header__link[data-active="true"] {
    color: var(--text-strong);
  }

  .site-header__link[data-active="true"]::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 2px;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    transform: translateX(-50%);
    background: var(--text-strong);
  }

  .site-header__cta {
    position: relative;
    z-index: 1;
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .site-header__locale {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 34px;
    min-width: 38px;
    padding-inline: 10px;
    border-radius: var(--radius-md);
    color: var(--muted-strong);
    font-size: 12px;
    font-weight: 700;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: rgba(255, 255, 255, 0.42);
  }

  .site-header__locale:hover {
    color: var(--text-strong);
    border-color: rgba(15, 23, 42, 0.16);
  }

  .site-header__cta-btn {
    height: 40px;
    padding-inline: 16px;
    font-size: 13.5px;
    gap: 6px;
  }

  .site-header__cta-btn svg {
    transition: transform var(--duration-ui) var(--ease-ui);
  }

  .site-header__cta-btn:hover svg {
    transform: translateX(3px);
  }

  @media (min-width: 880px) {
    .site-header__nav {
      display: inline-flex;
    }
    .site-header__cta {
      margin-left: 0;
      flex-shrink: 0;
    }
    .site-header__brand {
      flex-shrink: 0;
    }
  }

  @media (min-width: 880px) and (max-width: 1180px) {
    .site-header__inner {
      flex-wrap: wrap;
      row-gap: 10px;
    }
    .site-header__nav {
      order: 3;
      width: 100%;
    }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>("[data-site-header]");
  if (header) {
    const hero = document.getElementById("hero");

    const onScroll = () => {
      header.dataset.scrolled = window.scrollY > 8 ? "true" : "false";
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });

    if (hero) {
      const heroObserver = new IntersectionObserver(
        ([entry]) => {
          const onHero =
            entry.isIntersecting && entry.intersectionRatio > 0.12;
          header.dataset.pastHero = onHero ? "false" : "true";
        },
        { threshold: [0, 0.12, 0.35, 0.6, 1] }
      );
      heroObserver.observe(hero);
    } else {
      header.dataset.pastHero = "true";
    }

    const links = Array.from(
      document.querySelectorAll<HTMLAnchorElement>("[data-section-link]")
    );
    const sectionMap = new Map<string, HTMLAnchorElement>();
    links.forEach((link) => {
      const id = link.dataset.sectionLink;
      if (id) sectionMap.set(id, link);
    });

    const setActive = (id: string) => {
      links.forEach((link) => {
        link.dataset.active = link.dataset.sectionLink === id ? "true" : "false";
      });
    };

    const sections = Array.from(sectionMap.keys())
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => Boolean(el));

    if (sections.length) {
      const io = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
          if (visible[0]) setActive(visible[0].target.id);
        },
        { rootMargin: "-40% 0px -55% 0px", threshold: [0, 0.25, 0.5, 0.75, 1] }
      );
      sections.forEach((s) => io.observe(s));
    }
  }
</script>