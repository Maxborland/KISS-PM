---
import HeroShader from "./HeroShader.tsx";
import { copyFor, type LandingLocale } from "../lib/landing-i18n";

interface Props {
  locale?: LandingLocale;
}

const { locale = "ru" } = Astro.props;
const copy = copyFor(locale).hero;
---

<section id="hero" class="hero" aria-labelledby="hero-title">
  <HeroShader client:load />

  <div class="l-container hero__inner">
    <h1 id="hero-title" class="hero__title" data-text-reveal>{copy.title[0]}<br />{copy.title[1]}</h1>
    <p class="hero__copy">{copy.copy}</p>
    <a class="hero__access l-btn l-btn--primary" href="#waitlist">{copy.cta}</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-width: 100%;
    min-height: 100svh;
    display: grid;
    place-items: center;
    overflow: hidden;
    background:
      linear-gradient(
        118deg,
        rgba(223, 232, 255, 0.94) 0%,
        rgba(248, 251, 255, 0.98) 46%,
        rgba(232, 239, 255, 0.94) 100%
      ),
      var(--canvas);
    isolation: isolate;
    margin-bottom: 0;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      radial-gradient(ellipse 52% 32% at 50% 48%, rgba(255, 255, 255, 0.68) 0%, rgba(255, 255, 255, 0.36) 42%, rgba(255, 255, 255, 0) 74%),
      linear-gradient(
        180deg,
        rgba(238, 240, 244, 0.08) 0%,
        rgba(238, 240, 244, 0) 52%,
        rgba(238, 240, 244, 0) 100%
      );
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: -12%;
    z-index: 0;
    pointer-events: none;
    background:
      conic-gradient(
        from 218deg at 52% 46%,
        rgba(37, 99, 235, 0.22),
        rgba(125, 211, 252, 0.22),
        rgba(255, 255, 255, 0.5),
        rgba(79, 70, 229, 0.18),
        rgba(37, 99, 235, 0.22)
      ),
      linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.64),
        rgba(219, 234, 254, 0.34) 45%,
        rgba(238, 240, 244, 0.08)
      );
    background-position: 45% 48%, 50% 50%;
    background-size: 136% 136%, 100% 100%;
    opacity: 0.78;
    animation: kp-hero-atmosphere-drift 18s var(--ease-in-out) infinite alternate;
  }

  @keyframes kp-hero-atmosphere-drift {
    from {
      background-position: 42% 46%, 50% 50%;
      transform: translate3d(-1.5%, -1%, 0) scale(1.01);
    }
    to {
      background-position: 58% 54%, 50% 50%;
      transform: translate3d(1.5%, 1%, 0) scale(1.03);
    }
  }

  .hero__inner {
    position: relative;
    z-index: 3;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding-block: clamp(96px, 12vw, 156px);
  }

  :global(.hero-shader) {
    position: absolute;
    inset: 0;
    width: 100vw;
    min-width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: auto;
    opacity: 0;
    transform: scale(1.025);
    filter: blur(8px) saturate(1.08);
    transition:
      opacity 1200ms var(--ease-reveal),
      transform 1400ms var(--ease-reveal),
      filter 1400ms var(--ease-reveal);
  }

  :global(.hero-shader[data-shader-ready="true"]) {
    opacity: 0.56;
    transform: scale(1);
    filter: blur(0) saturate(1.08);
  }

  :global(.hero-shader__canvas) {
    width: 100vw;
    min-width: 100%;
    height: 100%;
    display: block;
  }

  .hero__title {
    max-width: min(980px, calc(100vw - 36px));
    margin: 0;
    color: color-mix(in oklab, var(--text-strong) 86%, var(--accent) 14%);
    font-family: var(--font-display);
    font-size: clamp(34px, 3.8vw, 56px);
    font-weight: var(--weight-heading);
    font-variation-settings: "wght" var(--weight-heading);
    line-height: 1.1;
    letter-spacing: 0;
    text-align: center;
    white-space: nowrap;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.6), 0 12px 40px rgba(255, 255, 255, 0.55);
  }

  .hero__copy {
    max-width: min(720px, calc(100vw - 48px));
    margin: clamp(18px, 3vh, 28px) 0 0;
    color: color-mix(in oklab, var(--text-strong) 70%, var(--muted) 30%);
    font-size: clamp(16px, 1.45vw, 20px);
    font-weight: 500;
    line-height: 1.55;
    text-align: center;
    text-wrap: balance;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.56);
  }

  .hero__access {
    position: relative;
    z-index: 4;
    margin-top: clamp(22px, 3.4vh, 38px);
    min-width: 172px;
    justify-content: center;
    box-shadow:
      0 18px 42px -22px rgba(37, 99, 235, 0.55),
      0 1px 0 rgba(255, 255, 255, 0.42) inset;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero::after {
      animation: none;
    }

    :global(.hero-shader) {
      transition: none;
      transform: none;
      filter: saturate(1.04);
    }

    :global(.hero-shader[data-shader-ready="true"]) {
      opacity: 0.48;
      filter: saturate(1.04);
    }
  }

  @media (max-width: 520px) {
    .hero__title {
      font-size: clamp(28px, 10vw, 40px);
      white-space: normal;
    }

    .hero__copy {
      font-size: 15.5px;
      line-height: 1.5;
    }
  }

  @media (min-width: 521px) and (max-width: 920px) {
    .hero__title {
      font-size: clamp(34px, 7vw, 52px);
      white-space: normal;
      text-wrap: balance;
    }
  }
</style>