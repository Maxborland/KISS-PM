---
import WaitlistForm from "./WaitlistForm.tsx";
import { copyFor, type LandingLocale } from "../lib/landing-i18n";

interface Props {
  locale?: LandingLocale;
}

const { locale = "ru" } = Astro.props;
const copy = copyFor(locale).waitlist;
---

<section id="waitlist" class="l-band l-band--canvas" aria-labelledby="waitlist-title">
  <div class="l-container">
    <div class="waitlist">
      <header class="waitlist__head section-head section-head--tight">
        <h2 id="waitlist-title" class="l-display" data-text-reveal>
          {copy.title}
        </h2>
        <p class="section-head__copy" data-text-reveal>{copy.copy}</p>
      </header>

      <div class="waitlist__panel kp-spotlight-card" data-reveal>
        <WaitlistForm locale={locale} client:visible />
      </div>
    </div>
  </div>
</section>