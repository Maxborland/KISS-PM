---
import "../styles/base.css";
import "../styles/glass.css";

interface AlternateLink {
  hrefLang: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  prerender?: boolean;
  structuredData?: Array<Record<string, unknown>>;
  lang?: string;
  skipLink?: string;
  alternates?: ReadonlyArray<AlternateLink>;
}

const {
  title,
  description = "KISS PM — управление проектами, ресурсами и сигналами без хаоса. Закрытая альфа.",
  structuredData = [],
  lang = "ru",
  skipLink = "Перейти к содержимому",
  alternates = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://kisspm.app").toString();
const ogImage = new URL("/og-image.png", Astro.site ?? "https://kisspm.app").toString();
const structuredDataJson = structuredData.map((item) => JSON.stringify(item));
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0f172a" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.hrefLang} href={alternate.href} />
    ))}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,650;12..96,700&family=IBM+Plex+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
    />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="KISS PM" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {structuredDataJson.map((json) => (
      <script is:inline type="application/ld+json" set:html={json}></script>
    ))}
  </head>
  <body>
    <a class="sr-only" href="#main">{skipLink}</a>
    <slot name="header" />
    <slot name="notifications" />
    <main id="main">
      <slot />
    </main>
    <slot name="footer" />
    <script>
      import "../scripts/enhance.ts";
    </script>
  </body>
</html>