---
import BaseLayout from "./BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface LegalFrontmatter {
  title?: string;
  updated?: string;
  description?: string;
}

interface Props extends LegalFrontmatter {
  frontmatter?: LegalFrontmatter;
}

const frontmatter = Astro.props.frontmatter ?? {};
const title = Astro.props.title ?? frontmatter.title ?? "Юридическая страница";
const updated = Astro.props.updated ?? frontmatter.updated ?? "";
const description = Astro.props.description ?? frontmatter.description ?? title;
---

<BaseLayout title={`${title} · KISS PM`} description={description}>
  <SiteHeader slot="header" />

  <article class="l-section legal">
    <div class="l-container l-container--narrow">
      <span class="l-eyebrow">Юридическая страница</span>
      <h1 class="l-h2 legal__title">{title}</h1>
      {updated ? <p class="l-muted legal__updated">Обновлено: {updated}</p> : null}

      <div class="legal__body">
        <slot />
      </div>
    </div>
  </article>

  <SiteFooter slot="footer" />
</BaseLayout>

<style is:global>
  .legal__title { margin-top: 14px; }
  .legal__updated { margin-top: 6px; font-size: 13px; }
  .legal__body {
    margin-top: 32px;
    font-size: 15px;
    line-height: 1.7;
    color: var(--text);
  }
  .legal__body h2 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: var(--text-strong);
    margin: 32px 0 12px;
  }
  .legal__body h3 {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: var(--text-strong);
    margin: 24px 0 8px;
  }
  .legal__body p { margin-bottom: 14px; }
  .legal__body ul, .legal__body ol {
    margin: 0 0 14px;
    padding-left: 22px;
    display: grid;
    gap: 4px;
  }
  .legal__body a {
    color: var(--accent);
    border-bottom: 1px dashed currentColor;
  }
  .legal__body code {
    font-family: var(--font-mono);
    background: var(--panel-strong);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 13px;
  }
</style>
