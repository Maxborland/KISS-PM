---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import HeroSection from "../components/HeroSection.astro";
import LandingAgentDemoSection from "../components/LandingAgentDemoSection.astro";
import PhilosophySection from "../components/PhilosophySection.astro";
import PathSection from "../components/PathSection.astro";
import DemoSection from "../components/DemoSection.astro";
import WaitlistSection from "../components/WaitlistSection.astro";
import FaqSection from "../components/FaqSection.astro";
import { copyFor } from "../lib/landing-i18n";
import { createLandingStructuredData } from "../lib/landing-structured-data";

export const prerender = true;

const locale = "en";
const page = copyFor(locale);
const structuredData = createLandingStructuredData(locale);
---

<BaseLayout
  title={page.title}
  description={page.description}
  lang={page.lang}
  skipLink={page.skipLink}
  alternates={page.alternates}
  structuredData={structuredData}
>
  <SiteHeader slot="header" locale={locale} />

  <HeroSection locale={locale} />
  <LandingAgentDemoSection locale={locale} />
  <PhilosophySection locale={locale} />
  <PathSection locale={locale} />
  <DemoSection locale={locale} />
  <FaqSection locale={locale} />
  <WaitlistSection locale={locale} />

  <SiteFooter slot="footer" locale={locale} />
</BaseLayout>