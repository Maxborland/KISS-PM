---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import HeroSection from "../components/HeroSection.astro";
import LandingAgentDemoSection from "../components/LandingAgentDemoSection.astro";
import PhilosophySection from "../components/PhilosophySection.astro";
import PathSection from "../components/PathSection.astro";
import DemoSection from "../components/DemoSection.astro";
import WaitlistSection from "../components/WaitlistSection.astro";
import FaqSection from "../components/FaqSection.astro";
import { faqs } from "../lib/landing-faq";

export const prerender = true;

const siteUrl = "https://kisspm.app/";
const description =
  "KISS PM — agent-first управление проектами как код: опишите цель, получите сверку изменений по задачам, срокам и ресурсам, примените выбранное с аудитом.";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "KISS PM",
    url: siteUrl,
    logo: "https://kisspm.app/favicon.svg",
    description,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "KISS PM",
    url: siteUrl,
    inLanguage: "ru-RU",
    description,
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "KISS PM",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: siteUrl,
    description,
    softwareVersion: "closed alpha",
    isAccessibleForFree: true,
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "RUB",
      availability: "https://schema.org/PreOrder",
      description: "Закрытая альфа по заявке.",
    },
    additionalProperty: [
      {
        "@type": "PropertyValue",
        name: "Product status",
        value: "pre-release / closed alpha",
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((item) => ({
      "@type": "Question",
      name: item.q,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.a,
      },
    })),
  },
];
---

<BaseLayout
  title="KISS PM — управление проектами как код"
  description={description}
  structuredData={structuredData}
>
  <SiteHeader slot="header" />

  <HeroSection />
  <LandingAgentDemoSection />
  <PhilosophySection />
  <PathSection />
  <DemoSection />
  <FaqSection />
  <WaitlistSection />

  <SiteFooter slot="footer" />
</BaseLayout>
