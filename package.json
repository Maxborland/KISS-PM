{
  "name": "kiss-pm",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "scripts": {
    "dev:api": "pnpm --filter @kiss-pm/api dev",
    "dev:web": "pnpm --filter @kiss-pm/web dev",
    "dev:web:lan": "pnpm --filter @kiss-pm/web dev:lan",
    "dev:landing": "pnpm --filter @kiss-pm/landing dev",
    "dev:storybook:lan": "pnpm --filter @kiss-pm/web storybook:lan",
    "dev:compose": "docker compose up postgres api web",
    "dev:compose:detached": "docker compose up -d postgres api web",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "pnpm --filter @kiss-pm/persistence db:migrate",
    "db:seed:dev": "tsx scripts/seed-dev.ts",
    "db:reset:dev": "pnpm db:migrate && pnpm db:seed:dev",
    "test": "vitest run",
    "test:db": "vitest run --config vitest.db.config.ts",
    "test:e2e:smoke": "pnpm db:migrate && pnpm db:seed:dev && playwright test --config playwright.config.ts",
    "qa:runtime": "pnpm db:migrate && pnpm db:seed:dev && node scripts/run-runtime-qa.mjs",
    "typecheck": "tsc -b --pretty false",
    "build": "pnpm --filter @kiss-pm/web build && pnpm typecheck",
    "verify:storybook-contract": "pnpm --filter @kiss-pm/web verify:storybook-contract"
  },
  "devDependencies": {
    "@kiss-pm/persistence": "workspace:*",
    "@kiss-pm/test-fixtures": "workspace:*",
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.15.21",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.2",
    "hono": "^4.7.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.14"
    }
  }
}
