{
  "name": "kiss-pm",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -ws --if-present",
    "dev:api": "npm run dev -w @kiss-pm/api --",
    "dev:web": "npm run dev -w @kiss-pm/web --",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run apps/api/src",
    "test:e2e": "node scripts/run-e2e.mjs all",
    "test:e2e:smoke": "node scripts/run-e2e.mjs smoke",
    "test:e2e:critical": "node scripts/run-e2e.mjs critical",
    "test:e2e:permissions": "node scripts/run-e2e.mjs permissions",
    "test:e2e:phase": "node scripts/run-e2e.mjs phase",
    "verify:matrix": "node scripts/verify-requirements-matrix.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "5.100.10",
    "@vitejs/plugin-react": "^5.1.1",
    "hono": "^4.10.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "shadcn": "^4.7.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  }
}
