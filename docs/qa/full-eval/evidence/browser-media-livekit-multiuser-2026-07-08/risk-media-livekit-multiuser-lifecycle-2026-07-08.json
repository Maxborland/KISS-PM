  "codeFixes": {
    "strictModeJoinTokenGuard": "useCallEngine now returns after joinOrStartCallSession if disposed, before fetchJoinToken/fetchTurnCredentials, preventing unmounted dev StrictMode pass from emitting join_token_issued."
