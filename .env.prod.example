# ============================================================================
# KISS PM — production environment (docker-compose.prod.yml)
# Copy to .env on the deployment host and fill in real values.
#   cp .env.prod.example .env
# NEVER commit the filled-in .env. Values marked REQUIRED must be set or the
# stack fails to start (compose or the API refuses to boot).
# ============================================================================

# ── Public domain & TLS (Caddy) ─────────────────────────────────────────────
# REQUIRED. The domain whose DNS A/AAAA record points at this host. Caddy uses
# it to obtain a Let's Encrypt certificate automatically.
KISS_PM_DOMAIN=pm.example.com
# REQUIRED. ACME contact email for certificate issuance / expiry notices.
KISS_PM_ACME_EMAIL=ops@example.com
# REQUIRED. The browser-facing https origin (scheme + host, no trailing slash).
# Used as KISS_PM_TRUSTED_MUTATION_ORIGINS — without it every browser POST/PATCH
# is rejected as a cross-origin mutation. Must match https://<KISS_PM_DOMAIN>.
KISS_PM_PUBLIC_ORIGIN=https://pm.example.com

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# REQUIRED. No default — the stack refuses to start without a real password.
# ВАЖНО: пароль вклеивается в DATABASE_URL (postgres://user:PASSWORD@...), поэтому
# используйте URL-safe набор (буквы/цифры/-_.~); символы / # ? @ : сломают URL.
KISS_PM_POSTGRES_PASSWORD=change_me_use_a_long_random_secret
# Optional (defaults shown). DATABASE_URL is derived from these by compose, so
# you do not set DATABASE_URL directly.
KISS_PM_POSTGRES_USER=kiss_pm
KISS_PM_POSTGRES_DB=kiss_pm

# ── Core runtime (set by compose; listed here for reference) ─────────────────
# These are enforced in docker-compose.prod.yml and normally need no override:
#   NODE_ENV=production
#   HOST=0.0.0.0
#   PORT=4000
#   REDIS_URL=redis://redis:6379
#   PLANNING_EVENTS_BACKEND=redis
#   WORKSPACE_EVENTS_BACKEND=redis
#   PLANNING_EVENTS_REDIS_ALLOW_INSECURE=true   # internal redis, no TLS on the compose net
#   KISS_PM_BACKGROUND_JOBS_ENABLED=true
#   KISS_PM_ENABLE_DEV_ROUTES is intentionally NOT set (dev routes forbidden in prod)
#   KISS_PM_SECURE_COOKIES defaults to true in production

# ── Object storage ──────────────────────────────────────────────────────────
# Default is local-root on a named docker volume (no S3 required). The path
# (/var/lib/kiss-pm/storage) and provider are set by compose. To use S3-compatible
# storage instead, set KISS_PM_STORAGE_PROVIDER=s3 and the S3_* vars below.
# KISS_PM_STORAGE_PROVIDER=s3
# KISS_PM_STORAGE_S3_BUCKET=
# KISS_PM_STORAGE_S3_REGION=us-east-1
# KISS_PM_STORAGE_S3_ENDPOINT=https://s3.example.com
# KISS_PM_STORAGE_S3_ACCESS_KEY_ID=
# KISS_PM_STORAGE_S3_SECRET_ACCESS_KEY=

# ── AI agent (LLM provider) ─────────────────────────────────────────────────
# REQUIRED for AI features. Provider auto-selects (OpenRouter → Anthropic → demo);
# set explicitly for production. Keys are server-side only and never logged.
KISS_PM_AGENT_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-...
KISS_PM_AGENT_MODEL=anthropic/claude-3.7-sonnet
# Optional tuning:
# KISS_PM_AGENT_MAX_TOKENS=1024
# KISS_PM_AGENT_MAX_ITERATIONS=6
# KISS_PM_AGENT_MAX_OUTPUT_TOKENS=16000
# KISS_PM_AGENT_TIMEOUT_MS=60000

# ── Email (password reset) ──────────────────────────────────────────────────
# REQUIRED in production: without KISS_PM_EMAIL_PROVIDER=smtp + host/from the API
# fails closed on startup (memory provider is forbidden in prod).
KISS_PM_EMAIL_PROVIDER=smtp
KISS_PM_SMTP_HOST=smtp.example.com
KISS_PM_SMTP_PORT=587
KISS_PM_SMTP_FROM="KISS PM <noreply@example.com>"
KISS_PM_SMTP_USERNAME=apikey
KISS_PM_SMTP_PASSWORD=change_me
# Optional (defaults shown):
# KISS_PM_SMTP_SECURE=false        # true = implicit TLS on 465
# KISS_PM_SMTP_REQUIRE_TLS=true    # defaults to true in production

# ── Video / media plane (optional, opt-in) ──────────────────────────────────
# Off by default. Only set these to run self-hosted A/V (LiveKit). In production
# with provider=livekit, KISS_PM_MEDIA_READINESS_URL is required (fail-closed).
# KISS_PM_VIDEO_PROVIDER=livekit
# KISS_PM_VIDEO_LIVEKIT_URL=wss://livekit.example.com
# KISS_PM_VIDEO_LIVEKIT_API_KEY=
# KISS_PM_VIDEO_LIVEKIT_API_SECRET=
# KISS_PM_MEDIA_READINESS_URL=http://livekit:7880
