{
  "version": 1,
  "updated_at": "2026-05-15T04:00:00+07:00",
  "exclusive_paths": [
    "AGENTS.md",
    ".gitignore",
    "package.json",
    "package-lock.json",
    "docs/status/*",
    ".agent-bus/state/*",
    ".agent-bus/queue.json",
