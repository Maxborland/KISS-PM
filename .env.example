KISS_PM_POSTGRES_DB=kiss_pm
KISS_PM_POSTGRES_USER=kiss_pm
KISS_PM_POSTGRES_PASSWORD=kiss_pm_dev_password
KISS_PM_POSTGRES_PORT=55432
DATABASE_URL=postgres://kiss_pm:kiss_pm_dev_password@127.0.0.1:55432/kiss_pm

# --- Media plane (self-hosted LiveKit). OPT-IN: needed only to run audio/video calls. ---
# Start the media service: docker compose --profile media up
# Then uncomment the lines below (values must match infra/livekit/livekit.yaml `keys`).
# KISS_PM_VIDEO_PROVIDER=livekit
# KISS_PM_VIDEO_LIVEKIT_URL=ws://localhost:7880            # browser-reachable signaling URL (dev)
# KISS_PM_VIDEO_LIVEKIT_API_KEY=devkey
# KISS_PM_VIDEO_LIVEKIT_API_SECRET=devsecret_change_me_min_32_chars_0123456789
# KISS_PM_VIDEO_TOKEN_TTL_SECONDS=600                       # bounded 60..3600
# KISS_PM_VIDEO_ALLOW_INSECURE_HTTP=true                    # DEV ONLY (allows ws://); never in production
# KISS_PM_MEDIA_READINESS_URL=http://livekit:7880           # api -> livekit health probe (compose DNS)
