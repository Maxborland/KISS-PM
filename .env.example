KISS_PM_POSTGRES_DB=kiss_pm
KISS_PM_POSTGRES_USER=kiss_pm
KISS_PM_POSTGRES_PASSWORD=kiss_pm_dev_password
KISS_PM_POSTGRES_PORT=55432
DATABASE_URL=postgres://kiss_pm:kiss_pm_dev_password@127.0.0.1:55432/kiss_pm

# --- Media plane (self-hosted LiveKit). OPT-IN: needed only to run audio/video calls. ---
# Start the media service: docker compose --profile media up
# Then uncomment the lines below (values must match infra/livekit/livekit.yaml `keys`).
# KISS_PM_VIDEO_PROVIDER=livekit
# KISS_PM_VIDEO_LIVEKIT_URL=ws://localhost:7880            # browser-reachable signaling URL (dev)
# KISS_PM_VIDEO_LIVEKIT_HTTP_URL=http://livekit:7880       # server-reachable URL for egress (compose DNS); falls back to deriving http(s) from the ws URL
# KISS_PM_VIDEO_LIVEKIT_API_KEY=kisspmdevkey
# KISS_PM_VIDEO_LIVEKIT_API_SECRET=devsecret_change_me_min_32_chars_0123456789
# KISS_PM_VIDEO_TOKEN_TTL_SECONDS=600                       # bounded 60..3600
# KISS_PM_VIDEO_ALLOW_INSECURE_HTTP=true                    # DEV ONLY (allows ws://); never in production
# KISS_PM_MEDIA_READINESS_URL=http://livekit:7880           # api -> livekit health probe (compose DNS)
# --- TURN (standalone coturn) + per-track Egress recording (Phase 5/6) ---
# KISS_PM_TURN_URL=turns:turn.example.com:5349,turn:turn.example.com:3478
# KISS_PM_TURN_SHARED_SECRET=turn_shared_secret_change_me   # server-side only; never logged
# KISS_PM_TURN_CREDENTIAL_TTL_SECONDS=600                   # bounded 60..3600
# KISS_PM_VIDEO_EGRESS_ENABLED=false                        # true requires provider=livekit AND storage=s3
# KISS_PM_VIDEO_LIVEKIT_WEBHOOK_VERIFY=true

# --- Password reset email delivery. Dev/test default is in-memory; production defaults to SMTP and fails closed without host/from. ---
# KISS_PM_EMAIL_PROVIDER=smtp
# KISS_PM_SMTP_HOST=smtp.example.com
# KISS_PM_SMTP_PORT=587
# KISS_PM_SMTP_FROM="KISS PM <noreply@example.com>"
# KISS_PM_SMTP_USERNAME=apikey
# KISS_PM_SMTP_PASSWORD=change_me
# KISS_PM_SMTP_SECURE=false
# KISS_PM_SMTP_REQUIRE_TLS=true

# ── AI-агент (LLM-провайдер) ────────────────────────────────────────────────
# Провайдер выбирается автоматически: OpenRouter (приоритет) → Anthropic → demo/mock.
# Явное переопределение: openrouter | anthropic | demo | mock.
# KISS_PM_AGENT_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...                  # server-side only; never logged
# ANTHROPIC_API_KEY=sk-ant-...                  # запасной провайдер
# KISS_PM_AGENT_MODEL=anthropic/claude-3.7-sonnet  # OpenRouter-слаг; для Anthropic — claude-sonnet-4-6
# KISS_PM_AGENT_MAX_TOKENS=1024                 # max_tokens на ответ
# KISS_PM_AGENT_MAX_ITERATIONS=6                # лимит шагов цикла
# KISS_PM_AGENT_MAX_OUTPUT_TOKENS=16000         # суммарный токен-бюджет на /propose
# KISS_PM_AGENT_TIMEOUT_MS=60000                # wall-clock дедлайн на /propose
# KISS_PM_AGENT_DEMO=true                        # детерминированный демо-«мозг» без ключа
